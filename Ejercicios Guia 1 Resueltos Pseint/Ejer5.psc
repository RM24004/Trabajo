Algoritmo Ejer5
	Definir not1, not2, not3, pro Como Real
	Escribir "Ingrese nota 1 "
	Leer not1
	Escribir "Ingrese nota 2 "
	Leer not2
	Escribir "Ingrese nota 3 "
	Leer not3
	pro<-(not1+not2+not3)/3
	Si pro>=6 Entonces
		Escribir "su promedio es: ", pro
		Escribir "aprobado"
	SiNo
		Escribir "su promedio es: ", pro
		Escribir "reprobado"
	Fin Si
FinAlgoritmo
