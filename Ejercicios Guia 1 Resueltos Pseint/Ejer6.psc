Algoritmo Ejer6
	Definir num1, num2 Como Entero
	Escribir "Ingrese el numero 1"
	Leer num1
	Escribir "Ingrese el numero 2"
	Leer num2
	Si num1 > num2 Entonces
		Escribir "El numero 1 = ", num1 ," es mayor"
	SiNo
		Si num2 > num1 Entonces
			Escribir "El numero 2 = ", num2 ," es mayor"
		SiNo
			Escribir "El numero 1= ", num1 " Y el numero 2= ", num2 ," son iguales"
		FinSi
	Fin Si
FinAlgoritmo
